	then mv -f "$(DEPDIR)/gico3-read.Tpo" "$(DEPDIR)/gico3-read.Po"; else rm -f "$(DEPDIR)/gico3-read.Tpo"; exit 1; fi
#	source='read.c' object='gico3-read.obj' libtool=no \
#	DEPDIR=$(DEPDIR) $(CCDEPMODE) $(depcomp) \
#	$(CC) $(DEFS) $(DEFAULT_INCLUDES) $(INCLUDES) $(AM_CPPFLAGS) $(CPPFLAGS) $(gico3_CFLAGS) $(CFLAGS) -c -o gico3-read.obj `if test -f 'read.c'; then $(CYGPATH_W) 'read.c'; else $(CYGPATH_W) '$(srcdir)/read.c'; fi`

